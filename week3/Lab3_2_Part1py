# --- Lab 3.2 Part 1: Countdown Timer ---
start = int(input("Enter starting number for countdown: "))

while start >= 0:
    # 1. พิมพ์ตัวเลขในแต่ละรอบตามฟอร์แมตที่กำหนด
    print(f"Countdown: {start}")
    
    # 2. ลดค่าของ start ลงทีละ 1 เพื่อขยับเข้าใกล้เงื่อนไขสิ้นสุดลูป
    start -= 1

# เมื่อหลุดออกจากลูป (ค่าน้อยกว่า 0) ให้พิมพ์ข้อความฉลอง
print("Blast off!")